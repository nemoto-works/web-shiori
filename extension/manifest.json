{
  "manifest_version": 3,
  "name": "web-shiori",
  "version": "0.1.3",
  "description": "Chrome extension: save next actions per URL + page position.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "storage.js",
        "contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
